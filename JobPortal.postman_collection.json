            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated Job Title\",\n    \"company_name\": \"Tech Solutions Inc.\",\n    \"location\": \"Remote\",\n    \"salary\": \"$105,000 - $125,000\",\n    \"job_type\": \"Remote\",\n    \"description\": \"Updated description...\",\n    \"requirements\": \"Updated requirements...\",\n    \"status\": \"active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
