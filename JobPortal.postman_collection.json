            "url": {
              "raw": "{{base_url}}/jobs/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "jobs",
                "1"
              ]
            },
            "description": "Update an existing job posting. Only the posting owner (Employer) can modify it."
          },
          "response": []
